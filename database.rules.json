{
  "rules": {
    ".read": false,
    ".write": false,
    "products": {
      ".read": true,
      ".write": true,
      "$productId": {
        ".validate": "newData.hasChildren(['name', 'price', 'stock', 'desc'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 4"
        },
        "price": {
          ".validate": "newData.isNumber() && newData.val() >= 1000"
        },
        "stock": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "desc": {
          ".validate": "newData.isString() && newData.val().length >= 10"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
